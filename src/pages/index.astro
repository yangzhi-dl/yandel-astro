---
import AppFooter from "../components/AppFooter.astro";
import AppHeader from "../components/AppHeader.vue";
import HeroSection from "../components/HeroSection.astro";
import HomeFeatureGrid from "../components/HomeFeatureGrid.astro";
import NoteCard from "../components/NoteCard.astro";
import ProjectCard from "../components/ProjectCard.astro";
import SectionHeader from "../components/SectionHeader.astro";
import {
  homePage,
  notes,
  projects,
  siteConfig,
} from "../data/home";
import BaseLayout from "../layouts/BaseLayout.astro";

const featuredProjects = projects.filter((project) => project.featured);
const featuredNotes = notes.filter((note) => note.featured);
---

<BaseLayout title={homePage.seo.title} description={homePage.seo.description}>
  <main class="site-shell">
    <AppHeader
      brand={siteConfig.brand}
      navItems={siteConfig.navItems}
      currentPath={Astro.url.pathname}
    />

    <div class="space-y-24">
      <HeroSection
        eyebrow={homePage.hero.eyebrow}
        title={homePage.hero.title}
        highlight={homePage.hero.highlight}
        description={homePage.hero.description}
        actions={homePage.hero.actions}
        metaItems={homePage.hero.metaItems}
      />

      <section class="grid gap-8 lg:grid-cols-[0.8fr_1.2fr] lg:items-start">
        <div>
          <div class="mb-4 text-sm font-medium uppercase text-emerald-200/80">
            Intro
          </div>
          <h2 class="m-0 text-3xl font-semibold text-stone-50">
            {homePage.intro.title}
          </h2>
          <p class="mt-4 leading-8 text-stone-400">
            {homePage.intro.description}
          </p>
        </div>

        <HomeFeatureGrid links={homePage.entryLinks} />
      </section>

      <section>
        <SectionHeader
          title="精选项目"
          description="先放最能代表当前方向的几个项目，后续可以自然扩展成项目详情页。"
          href="/projects"
          linkLabel="全部项目"
        />
        <div class="grid gap-4 md:grid-cols-3">
          {featuredProjects.map((project) => <ProjectCard project={project} />)}
        </div>
      </section>

      <section>
        <SectionHeader
          title="精选文章"
          description="文章入口先保持轻量，等外部平台和站内 Markdown 内容补齐后直接替换数据。"
          href="/notes"
          linkLabel="全部笔记"
        />
        <div class="grid gap-4 md:grid-cols-3">
          {featuredNotes.map((note) => <NoteCard note={note} />)}
        </div>
      </section>
    </div>

    <AppFooter
      brand={siteConfig.brand}
      description={siteConfig.footer.description}
      navItems={siteConfig.navItems}
      copyright={siteConfig.footer.copyright}
      domain={siteConfig.footer.domain}
    />
  </main>
</BaseLayout>
