---
interface Props {
  eyebrow: string;
  title: string;
  description: string;
}

const { eyebrow, title, description } = Astro.props;
---

<section class="max-w-3xl">
  <div class="mb-4 text-sm font-medium uppercase text-emerald-200/80">
    {eyebrow}
  </div>
  <h1 class="m-0 text-4xl font-semibold leading-tight text-stone-50 md:text-6xl">
    {title}
  </h1>
  <p class="mt-6 text-lg leading-8 text-stone-300">
    {description}
  </p>
</section>
