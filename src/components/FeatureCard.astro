---
interface Props {
  title: string;
  description: string;
  meta?: string;
  href?: string;
  id?: string;
}

const { title, description, meta, href, id } = Astro.props;
---

<article
  id={id}
  class="glass-panel group rounded-lg p-5 transition-colors"
>
  {meta && <div class="mb-4 text-xs uppercase text-emerald-200/80">{meta}</div>}
  <h2 class="m-0 mb-3 text-lg font-semibold text-stone-100">{title}</h2>
  <p class="m-0 text-sm leading-7 text-stone-400">{description}</p>

  {
    href && (
      <a
        class="mt-5 inline-flex text-sm font-medium text-stone-200 transition-colors group-hover:text-emerald-200"
        href={href}
      >
        进入查看
      </a>
    )
  }
</article>
