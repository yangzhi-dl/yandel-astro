---
import type { ProjectItem } from "../data/home";

interface Props {
  project: ProjectItem;
}

const { project } = Astro.props;
---

<article
  class="flex h-full flex-col rounded-lg border border-white/10 bg-white/[0.035] p-5 transition-colors hover:border-emerald-300/35 hover:bg-white/[0.055]"
>
  <div class="mb-5 flex flex-wrap items-center gap-2 text-xs text-stone-400">
    <span class="rounded-md border border-white/10 px-2.5 py-1 text-emerald-200">
      {project.status}
    </span>
    <span>{project.year}</span>
  </div>

  <h2 class="m-0 text-xl font-semibold text-stone-50">{project.title}</h2>
  <p class="mt-3 leading-7 text-stone-400">{project.summary}</p>

  <div class="mt-5 flex flex-wrap gap-2">
    {
      project.tags.map((tag) => (
        <span class="rounded-md bg-white/[0.06] px-2.5 py-1 text-xs text-stone-300">
          {tag}
        </span>
      ))
    }
  </div>

  <ul class="mt-5 space-y-2 text-sm leading-6 text-stone-300">
    {
      project.highlights.map((highlight) => (
        <li class="flex gap-2">
          <span class="mt-2 h-1.5 w-1.5 shrink-0 rounded-sm bg-emerald-300"></span>
          <span>{highlight}</span>
        </li>
      ))
    }
  </ul>

  {
    project.href && (
      <a
        class="mt-auto pt-6 text-sm font-medium text-emerald-200 hover:text-emerald-100"
        href={project.href}
      >
        查看项目
      </a>
    )
  }
</article>
