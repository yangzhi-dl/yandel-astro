---
interface Props {
  title: string;
  description?: string;
  href?: string;
  linkLabel?: string;
}

const { title, description, href, linkLabel } = Astro.props;
---

<div class="mb-6 flex flex-col gap-4 md:flex-row md:items-end md:justify-between">
  <div>
    <h2 class="m-0 text-2xl font-semibold text-stone-50 md:text-3xl">{title}</h2>
    {description && <p class="mt-3 max-w-2xl leading-7 text-stone-400">{description}</p>}
  </div>

  {
    href && linkLabel && (
      <a class="text-sm font-medium text-emerald-200 hover:text-emerald-100" href={href}>
        {linkLabel}
      </a>
    )
  }
</div>
