---
import type { NoteItem } from "../data/home";

interface Props {
  note: NoteItem;
}

const { note } = Astro.props;
---

<article
  class="glass-panel rounded-lg p-5 transition-colors hover:border-sky-300/30"
>
  <div class="mb-4 flex flex-wrap items-center gap-2 text-xs text-stone-400">
    <span class="glass-chip rounded-md px-2.5 py-1 text-sky-200">
      {note.platform}
    </span>
    <span>{note.category}</span>
    <span>{note.status}</span>
  </div>

  <h2 class="m-0 text-xl font-semibold text-stone-50">{note.title}</h2>
  <p class="mt-3 leading-7 text-stone-400">{note.summary}</p>

  {
    note.href ? (
      <a class="mt-5 inline-flex text-sm font-medium text-sky-200 hover:text-sky-100" href={note.href}>
        阅读文章
      </a>
    ) : (
      <span class="mt-5 inline-flex text-sm text-stone-500">内容整理中</span>
    )
  }
</article>
